ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-opus-4-8
# Place this file at backend/.env to enable the Claude LLM agent.
# Without it, the app falls back to a rule-based planner.

# Optional: override SQLite session database path (default: backend/data/sessions.db)
# SESSION_DB_PATH=backend/data/sessions.db
